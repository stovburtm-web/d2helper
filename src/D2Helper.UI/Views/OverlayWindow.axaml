<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:D2Helper.UI.ViewModels"
        xmlns:q="using:D2Helper.Core.Quests"
        x:Class="D2Helper.UI.Views.OverlayWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="D2Helper Overlay"
        SizeToContent="WidthAndHeight"
        MinWidth="320" MaxWidth="480"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        SystemDecorations="None"
        ShowInTaskbar="False"
        Topmost="True"
        CanResize="False"
        Focusable="False"
        ShowActivated="False"
        WindowStartupLocation="Manual">
  <Window.Styles>
    <Style Selector="Border.questRow">
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="10,5"/>
      <Setter Property="Margin" Value="0,2,0,0"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Background" Value="#991B2030"/>
      <Setter Property="RenderTransform" Value="scale(1)"/>
      <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
      <Setter Property="Transitions">
        <Transitions>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.35"/>
          <BrushTransition Property="Background" Duration="0:0:0.35"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.questRow.completed">
      <Setter Property="Background" Value="#99173A20"/>
    </Style>
    <!-- Grade-кольори (накладаються поверх .completed). Перфект — золото, Good — зелений, Min — жовтий. -->
    <Style Selector="Border.questRow.completed.gradeMin">
      <Setter Property="Background" Value="#99554200"/>
      <Setter Property="BorderThickness" Value="0,0,0,2"/>
      <Setter Property="BorderBrush" Value="#FFE4A93C"/>
    </Style>
    <Style Selector="Border.questRow.completed.gradeGood">
      <Setter Property="Background" Value="#9919562E"/>
      <Setter Property="BorderThickness" Value="0,0,0,2"/>
      <Setter Property="BorderBrush" Value="#FF7BE08E"/>
    </Style>
    <Style Selector="Border.questRow.completed.gradePerfect">
      <Setter Property="Background" Value="#AA5C4818"/>
      <Setter Property="BorderThickness" Value="0,0,0,2"/>
      <Setter Property="BorderBrush" Value="#FFFFD24A"/>
    </Style>
    <Style Selector="Border.questRow.expired">
      <Setter Property="Background" Value="#88331818"/>
    </Style>
    <Style Selector="Border.questRow.pending">
      <Setter Property="Background" Value="#552A2F3A"/>
    </Style>
    <!-- DEADLINE WARNING: до due_at ≤ 30с і ще не виконав. Пульсує opacity щоб
         перехопити периферичний зір гравця. -->
    <Style Selector="Border.questRow.deadline">
      <Setter Property="Background" Value="#CC8B2A2A"/>
      <Setter Property="BorderThickness" Value="0,0,0,3"/>
      <Setter Property="BorderBrush" Value="#FFFF5252"/>
      <Style.Animations>
        <Animation Duration="0:0:0.7" IterationCount="INFINITE" Easing="SineEaseInOut" PlaybackDirection="Alternate">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Background" Value="#CC8B2A2A"/>
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="0.55"/>
            <Setter Property="Background" Value="#EEFF3838"/>
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <!-- "Celebrating" — тільки-но виконали. Підсвічуємо яскраво-зеленим
         + злегка "піднімаємо" рядок через RenderTransform-transition
         (keyframe-аніматор для RenderTransform в Avalonia 11 не зареєстрований —
          тому використовуємо transition між class-станами замість Animation). -->
    <Style Selector="Border.questRow.celebrating">
      <Setter Property="Background" Value="#CC2EE864"/>
      <Setter Property="RenderTransform" Value="scale(1.05)"/>
      <Style.Animations>
        <Animation Duration="0:0:0.9" IterationCount="1" Easing="QuadraticEaseOut">
          <KeyFrame Cue="0%">
            <Setter Property="Background" Value="#FF3CE07A"/>
            <Setter Property="Opacity" Value="0.85"/>
          </KeyFrame>
          <KeyFrame Cue="50%">
            <Setter Property="Background" Value="#FF3CE07A"/>
            <Setter Property="Opacity" Value="1"/>
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Background" Value="#CC2EE864"/>
            <Setter Property="Opacity" Value="1"/>
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <!-- Велика "✅" біля квеста-вкуснячки. -->
    <Style Selector="TextBlock.celebrateCheck">
      <Setter Property="Opacity" Value="0"/>
    </Style>
    <Style Selector="TextBlock.celebrateCheck.on">
      <Setter Property="Opacity" Value="1"/>
      <Style.Animations>
        <Animation Duration="0:0:0.7" IterationCount="1" Easing="QuadraticEaseOut">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0"/>
          </KeyFrame>
          <KeyFrame Cue="60%">
            <Setter Property="Opacity" Value="1"/>
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1"/>
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
  </Window.Styles>

  <!-- Без зовнішньої рамки/фону: тільки рядки. Це робить його "плаваючим" над грою. -->
  <ItemsControl ItemsSource="{Binding ActiveQuests}" Padding="4">
    <ItemsControl.ItemTemplate>
      <DataTemplate DataType="q:QuestProgress">
        <Border Classes="questRow"
                Classes.completed="{Binding Status, Converter={x:Static vm:StatusEqualsConverter.Completed}}"
                Classes.expired="{Binding Status, Converter={x:Static vm:StatusEqualsConverter.Expired}}"
                Classes.pending="{Binding Status, Converter={x:Static vm:StatusEqualsConverter.Pending}}"
                Classes.celebrating="{Binding IsCelebrating}"
                Classes.deadline="{Binding IsDeadlineSoon}"
                Classes.gradeMin="{Binding Grade, Converter={x:Static vm:GradeEqualsConverter.Min}}"
                Classes.gradeGood="{Binding Grade, Converter={x:Static vm:GradeEqualsConverter.Good}}"
                Classes.gradePerfect="{Binding Grade, Converter={x:Static vm:GradeEqualsConverter.Perfect}}">
          <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
            <!-- "Вкуснячка" — велика ✅, з'являється лише поки квест celebrating. -->
            <TextBlock Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                       Classes="celebrateCheck"
                       Classes.on="{Binding IsCelebrating}"
                       Text="✅" FontSize="22" Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       RenderTransformOrigin="50%,50%"/>
            <TextBlock Grid.Row="0" Grid.Column="1"
                       Text="{Binding Title}" Foreground="#ECF2FF" FontSize="12"
                       TextWrapping="Wrap"/>
            <TextBlock Grid.Row="0" Grid.Column="2"
                       Text="{Binding ProgressText}" Foreground="#FFD58A" FontSize="12"
                       FontWeight="Bold" Margin="8,0,0,0"/>
            <ProgressBar Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,4,0,0" Height="4"
                         Minimum="0" Maximum="{Binding Target}" Value="{Binding Current}"
                         Foreground="#7BC97F" Background="#22000000"/>
          </Grid>
        </Border>
      </DataTemplate>
    </ItemsControl.ItemTemplate>
  </ItemsControl>
</Window>
